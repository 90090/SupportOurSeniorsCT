---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'FaqPage';
  noindex?: boolean;
}

const { title, description, image, type, noindex } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
    />
    <slot name="head" />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="192x192" href="/192.png" />
    <link rel="shortcut icon" type="image/png" href="/512.png" />
    <link rel="apple-touch-icon" href="/32.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Preconnect to any external origins you load from -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <meta name="theme-color" content="#112F5B" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>