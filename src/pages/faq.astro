---
import Layout from '../layouts/Layout.astro';
import FAQAccordion from '../components/FAQAccordion';
import SEO from '../components/SEO.astro';
import JsonLD from '../components/JsonLD.astro';
---

<Layout 
  title="Frequently Asked Questions"
  description="Answers to common questions about senior care services, caregiver coordination, financial planning, and conservatorship guidance."
  image="/1200.png"
  type="FaqPage"
  >
  <JsonLD slot="head" schema={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a senior advocate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A senior advocate is a trusted professional who helps older adults and their families navigate aging-related challenges. This can include assistance with medical appointments, financial organization, household support, care coordination, and overall advocacy to ensure the senior's needs and wishes are respected.  At Supporting Our Seniors, our role is to provide clarity, guidance, and peace of mind — acting as an extra layer of support for both seniors and their families."
        }
      },
      {
        "@type": "Question",
        "name": "How can a senior advocate help my family?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A senior advocate helps reduce stress by managing details that often become overwhelming. We help families stay organized, informed, and proactive rather than reactive. This may include:  Attending medical appointments, advocating for the client and when applicable, reporting back to loved ones. Helping organize finances and paperwork. Coordinating care and services. Advocating for the senior's best interests. Supporting caregivers through complex decisions"
        }
      },
      {
        "@type": "Question",
        "name": "Do you replace an attorney, financial advisor, or healthcare provider?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. We do not replace legal, financial, or medical professionals. Instead, we work alongside them to ensure communication is clear, responsibilities are coordinated, and nothing is overlooked.  Many families find that having a senior advocate improves collaboration between professionals, reduces confusion during critical moments, and allows family to be family."
        }
      },
      {
        "@type": "Question",
        "name": "What types of seniors do you work with?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We work with seniors at many different stages of aging, including those who: Want to age safely and comfortably at home. Are managing chronic health conditions. Are experiencing memory or cognitive changes. Need help organizing finances or household responsibilities. Require advocacy due to complex family or care situations. Support can be short-term, long-term, or evolving as needs change."
        }
      },
      {
        "@type": "Question",
        "name": "Do you help clients with Alzheimer's, Dementia or memory loss?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We are experienced in supporting seniors with dementia and cognitive decline. As Certified Dementia Practitioners — and having personal experience with loved ones affected by memory loss — we approach every situation with patience, empathy, and deep understanding.  We also provide guidance and support to families and caregivers as they navigate the emotional and practical challenges that memory loss can bring."
        }
      },
      {
        "@type": "Question",
        "name": "What is a Certified Dementia Practitioner (CDP)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Certified Dementia Practitioner (CDP) is a professional who has completed specialized training in Alzheimer's and dementia care. This certification demonstrates a commitment to high standards in dementia education and person-centered care. Ongoing continuing education is required to maintain certification, ensuring current knowledge and best practices in dementia-related support."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between a senior advocate and a caregiver?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A caregiver typically provides hands-on personal care, such as bathing, dressing, or meal preparation. A senior advocate focuses on coordination, oversight, organization, and advocacy.  Our role is to ensure that care plans are appropriate, services are coordinated, and the senior's voice is heard — often working in partnership with caregivers and home care agencies."
        }
      },
      {
        "@type": "Question",
        "name": "Do you only work with seniors, or do you support family caregivers too?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We support both seniors and their family caregivers. Caregiving can be emotionally and physically demanding, and many caregivers feel overwhelmed or unsure of next steps.  Our services are designed to reduce family caregiver burnout by offering guidance, problem-solving, and an experienced advocate who can help shoulder the responsibility."
        }
      },
      {
        "@type": "Question",
        "name": "How does a Senior Advocate / Geriatric Care Manager help in real life?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Senior Advocate or Geriatric Care Manager provides hands-on support, experienced knowledge, and proactive action in both medical and home settings. We help families understand available options, identify appropriate care providers, and create strategic plans for the future. This may include coordinating specialist appointments, arranging transportation, organizing medical information, and managing communication between providers.  The healthcare system can be overwhelming and emotionally taxing. By leading coordination and communication, we allow families to focus on what matters most — spending quality time with their loved one — while receiving clear guidance, recommendations, and next steps."
        }
      },
      {
        "@type": "Question",
        "name": "Do you assist in Medicaid Applications?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, We provide skilled, hands-on support with Medicaid applications and eligibility navigation. Our assistance is tailored to each client's unique financial, medical, and family circumstances, ensuring the process is handled accurately, with clarity and confidence."
        }
      },
      {
        "@type": "Question",
        "name": "Is every situation handled the same way?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. There are no cookie-cutter solutions when it comes to senior care.  Every situation is approached individually and thoughtfully. We tailor our services creatively and strategically to ensure the goals, values, and best interests of the senior and family are met."
        }
      },
      {
        "@type": "Question",
        "name": "Can you help with conservatorship situations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Supporting Our Seniors provides experienced, court-informed Conservator services and support for families navigating Probate Court matters. We may serve directly as Conservator or assist a family member in that role.  Our services include management of court filings and compliance, financial oversight, record organization, day-to-day coordination, and communication among family members and care providers. We approach each case with compassion, accountability, and a clear commitment to protecting the dignity and best interests of the individual."
        }
      },
      {
        "@type": "Question",
        "name": "What is a Conservator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Conservator of the Person is appointed by the Connecticut Probate Court to supervise the personal affairs of an individual who is unable to meet essential needs such as food, clothing, shelter, healthcare, and safety.  A Conservator of the Estate is appointed to oversee the financial affairs of an individual who is unable to manage assets, income, or public assistance benefits."
        }
      },
      {
        "@type": "Question",
        "name": "Why do people have conservatorships?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Conservatorships allow a responsible individual to assume legal oversight when an adult can no longer safely manage personal or financial decisions. Families often pursue conservatorship to address increasing medical, financial, or mental health needs — and often when a Power of Attorney does not exist and is no longer a viable option.  Supporting Our Seniors has experience with Conservatorship of the Person and Estate, including voluntary, involuntary, and contested involuntary conservatorships. Tamath is also a vetted and approved Regulation 16 Conservator by the State of Connecticut."
        }
      },
      {
        "@type": "Question",
        "name": "Can you help families considering conservatorship?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If you are considering conservatorship for a loved one, we help families explore all available options and understand the implications before moving forward.  Our role is to guide and support families in making informed decisions that are in the best interest of the senior and appropriate for the specific situation."
        }
      },
      {
        "@type": "Question",
        "name": "What is a Daily Money Manager?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Daily Money Manager assists with day-to-day financial tasks such as reviewing mail, organizing bills, and ensuring bills are paid accurately and on time. Daily money management services are commonly used by seniors, caregivers, and individuals who want added oversight, accuracy, and peace of mind when managing financial responsibilities."
        }
      },
      {
        "@type": "Question",
        "name": "How does the process work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We begin with an initial consultation to understand your concerns, goals, and the senior's unique situation. Following the consultation, Supporting Our Seniors provides a proposal and draft Service Agreement that serves as a starting point for a final agreement tailored to your family's needs.  Once services are retained, a Certificate of Insurance endorsed to the client is provided. From there, support may include meetings with doctors, facility staff, the senior, and other professionals, as well as ongoing care coordination and advocacy."
        }
      },
      {
        "@type": "Question",
        "name": "What if support is needed urgently?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In some cases, families reach out during emergent or time-sensitive situations. Supporting Our Seniors has experience handling urgent circumstances and can fast-track the intake process when needed.  Our ability to hit the ground running allows us to provide immediate support, guidance, and advocacy during critical moments."
        }
      },
      {
        "@type": "Question",
        "name": "Where do you provide services?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We provide senior advocacy and support services throughout New Haven, Litchfield, and Fairfield counties in Connecticut. Service availability may vary by need, and we are happy to discuss location-specific questions during a consultation."
        }
      }
    ]
  }} />
  <section class="faq-hero bg-[var(--color-purple-dark)]">
    <div class="container ">
      <h1>Frequently Asked Questions</h1>
      <h3 class="text-xs mb-3 text-[var(--color-accent)] leading-tight">We understand that navigating senior care and support can feel overwhelming. Below are
      answers to some of the most common questions families ask when considering senior
      advocacy services.</h3>
    </div>
  </section>

  <section class="faq-content">
    <div class="container">
      <FAQAccordion client:load />
    </div>
  </section>

  <section class="py-14 md:py-20 bg-[var(--color-bg-alt)]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-purple-dark)] mb-4">
        Still Have Questions?
      </h2>
      <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)] mb-8">
        If you don't see your question answered here, we encourage you to reach out. Schedule a 
        consultation and learn how compassionate senior advocacy can support you and your loved ones.
      </p>
      <a 
        href="/#contact"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-[var(--color-accent)] text-white rounded-lg font-semibold text-base transition-all duration-300 hover:bg-[var(--color-purple-dark)] hover:-translate-y-1 hover:shadow-lg"
      >
        Contact Us
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .faq-hero {
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .faq-hero h1 {
    margin-bottom: 1rem;
  }

  .faq-hero p {
    font-size: 1.25rem;
    opacity: 0.95;
  }

  .faq-content {
    padding: 4rem 0;
  }

  @media (max-width: 768px) {
    .faq-hero {
      padding: 3rem 1.5rem;
    }

    .faq-content {
      padding: 3rem 0;
    }
  }
</style>